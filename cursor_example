
DECLARE 
	V_NAME EMPLOYEES.FIRST_NAME%TYPE;
	V_DEPT_NAME DEPARTMENTS.DEPARTMENT_NAME%TYPE;
	
	CURSOR C_EMP_NAME IS SELECT FIRST_NAME
							FROM EMPLOYEES
							WHERE DEPARTMENT_ID = 60;
	CURSOR C_DEPT_NAME IS SELECT DEPARTMENT_NAME 
							FROM DEPARTMENTS;
BEGIN	
	DBMS_OUTPUT.PUT_LINE('EMPLOYEE NAME :');
	OPEN C_EMP_NAME;
		LOOP
			FETCH C_EMP_NAME INTO V_NAME;
			EXIT WHEN C_EMP_NAME%NOTFOUND;
            DBMS_OUTPUT.PUT_LINE(V_NAME);
		END LOOP;	
	CLOSE C_EMP_NAME;
	
	DBMS_OUTPUT.PUT_LINE('DEPARTMENT NAME :');
	
	OPEN C_DEPT_NAME;
		LOOP
			FETCH C_DEPT_NAME INTO V_DEPT_NAME;
			EXIT WHEN C_DEPT_NAME%NOTFOUND;
			DBMS_OUTPUT.PUT_LINE(V_DEPT_NAME);
		END LOOP;
	CLOSE C_DEPT_NAME;

END;
/

